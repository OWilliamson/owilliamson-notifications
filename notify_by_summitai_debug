        incident_close( $client, $rest_endpoint, $db_id[0]{TICKET} );
        db_archive( $dbh, $db_id[0] );
    }
} 
else {
    my $ticket_id;
    if ( $db_id[0] ) {
        my $ticket_data = incident_search($client, $db_id[0]{TICKET});
        if ( $ticket_data ) {
            if ( $ticket_data->{TicketStatus} ne 'Closed' || $ticket_data->{TicketStatus} ne 'Cancelled' || $ticket_data->{TicketStatus} ne 'Closed' || $ticket_data->{TicketStatus} ne 'Resolved' ) {
                if ( ! $db_id[0]{ACK} ) {
                    my $logging_id = $ticket_data->{TicketIdentifier};
		    $logger->info('Sending ack for: ' $logging_id);
                    send_ack($socket, $env_vars, $ticket_data->{TicketIdentifier}, $debug_mode);
                    db_ack($dbh, $db_id[0]{TICKET});
                }
            }
            else {
                db_archive( $dbh, $db_id[0] );
                $ticket_id = incident_create( $client, $env_vars, $rest_endpoint, $config, %ai_data );
                $logger->info('Created ticket: ' $ticket_id);
		syslog('LOG_DEBUG', "Ticket ID: $ticket_id");
                if ( $ticket_id ) {
                    db_insert( $dbh, $env_vars, $ticket_id );
                    send_ack($socket, $env_vars, $ticket_id, $debug_mode);
                    db_ack($dbh, $db_id[0]{TICKET});
                }
            }
        }
        else {
            db_archive( $dbh, $db_id[0] );
            $ticket_id = incident_create( $client, $env_vars, $rest_endpoint, $config, %ai_data );
            syslog('LOG_DEBUG', "Ticket ID: $ticket_id");
            if ( $ticket_id ) {
                db_insert( $dbh, $env_vars, $ticket_id );
		$logger->info('Archiving: ' $ticket_id);
                send_ack($socket, $env_vars, $ticket_id, $debug_mode);
                db_ack($dbh, $db_id[0]{TICKET});
            }
        }
    } 
    else {
        $ticket_id = incident_create( $client, $env_vars, $config );
        syslog('LOG_DEBUG', "Ticket ID: $ticket_id");
	$logger->info('Created ticket: ' $ticket_id);
        if ( $ticket_id ) {
            db_insert( $dbh, $env_vars, $ticket_id );
            send_ack($socket, $env_vars, $ticket_id, $debug_mode);
            db_ack($dbh, $ticket_id);
        }
    }
}

sub db_init {
    my ($dbh) = @_;

    my $create_db = qq {
        CREATE TABLE IF NOT EXISTS tickets (
            ID          INTEGER PRIMARY KEY AUTOINCREMENT,
            DT          DATETIME DEFAULT CURRENT_TIMESTAMP,
            HOSTNAME    TEXT NOT NULL,
            SERVICE     TEXT,
            LASTOK      DATETIME DEFAULT CURRENT_TIMESTAMP,
            TICKET      CHAR(50),
            ACK         INT
        );
    };
  
    my $ret = $dbh->do($create_db);
    if ( $ret < 0 ) {
        print "Cannot run SQL $create_db: $DBI::errstr\n";
        return;
    }

    my $create_db_archive = qq {
        CREATE TABLE IF NOT EXISTS tickets_archive (
            ID          INTEGER PRIMARY KEY AUTOINCREMENT,
            DT          DATETIME DEFAULT CURRENT_TIMESTAMP,
            HOSTNAME    TEXT NOT NULL,
            SERVICE     TEXT,
            LASTOK      DATETIME DEFAULT CURRENT_TIMESTAMP,
            TICKET      CHAR(50),
            ACK         INT
        );
    };

    $ret = $dbh->do($create_db_archive);
    if ( $ret < 0 ) {
        print "Cannot run SQL $create_db_archive: $DBI::errstr\n";
        exit 3;
    }
}

sub env_setup {
    my $vars;
    my @env = (
        'NAGIOS_HOSTNAME', 
        'NAGIOS_HOSTGROUPNAME', 
        'NAGIOS_HOSTADDRESS', 
        'NAGIOS_HOSTSTATE', 
        'NAGIOS_HOSTSTATETYPE', 
        'NAGIOS_HOSTOUTPUT', 
        'NAGIOS_LASTHOSTCHECK', 
        'NAGIOS_LASTHOSTUP', 
        'NAGIOS_SERVICENOTES', 
        'NAGIOS_SERVICEDESC', 
        'NAGIOS_SERVICESTATE', 
        'NAGIOS_SERVICEOUTPUT', 
        'NAGIOS_SERVICESTATETYPE', 
        'NAGIOS_LASTSERVICECHECK', 
        'NAGIOS_LASTSERVICEOK',
        'NAGIOS_NOTIFICATIONTYPE',
        'OPSVIEW_KEYWORDS',
        'NAGIOS_LONGSERVICEOUTPUT'
    );

    for ( @env ) {
        $vars->{$_} = $ENV{$_};
    }
    if ($debug_mode) {
        syslog('LOG_DEBUG', "VARIABLES: " . pp($vars) );
    }
    syslog('LOG_DEBUG', "VARIABLES: " . pp($vars) );
    return $vars;
}

sub db_ack {
    my ( $dbh, $ticket_id ) = @_;

    $dbh->do(
        qq{ UPDATE tickets SET ACK = 1 WHERE TICKET = ? },
        {},
        $ticket_id,
    );
}

sub db_archive {
    my ( $dbh, $db_id ) = @_;

    my $sth = $dbh->prepare( "INSERT INTO tickets_archive (DT, HOSTNAME, SERVICE, LASTOK, TICKET, ACK) SELECT DT, HOSTNAME, SERVICE, LASTOK, TICKET, ACK FROM tickets WHERE ID = ?" );

    $sth->execute( $db_id[0]{ID} );

    $dbh->do( qq{DELETE FROM tickets WHERE ID = ?}, {}, $db_id[0]{ID} );

    $logger->info('DB Archived:' $db_id[0]{ID});
}

sub db_insert {
    my ( $dbh, $env_vars, $ticket_id ) = @_;

    $dbh->do( 
        qq{ INSERT INTO tickets 
        (DT, HOSTNAME, SERVICE, LASTOK, TICKET, ACK)
        VALUES (?,?,?,?,?,?); }, 
        {},
        time(),
        $env_vars->{'NAGIOS_HOSTNAME'},
        $env_vars->{'NAGIOS_SERVICEDESC'} || 'NULL',
        $env_vars->{'NAGIOS_LASTSERVICEOK'} || $env_vars->{'NAGIOS_LASTHOSTUP'},
        $ticket_id,
        0
    );
    $logger->info('DB Insert:' $ticket_id);

}

sub db_search {
    my ( $dbh, $env_vars ) = @_;

    my $sth = $dbh->prepare( "SELECT * FROM tickets WHERE HOSTNAME = ? AND SERVICE = ?" );

    if ( $env_vars->{'NAGIOS_SERVICEDESC'} ) {
        $sth->execute( $env_vars->{'NAGIOS_HOSTNAME'}, $env_vars->{'NAGIOS_SERVICEDESC'} );
    }
    else {
        $sth->execute( $env_vars->{'NAGIOS_HOSTNAME'}, 'NULL' );
    }
    my $row = $sth->fetchrow_hashref;

    syslog('LOG_DEBUG', pp($row) );
    $logger->info('DB Searched:' $row);

    return $row;
}

