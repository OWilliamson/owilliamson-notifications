sub incident_search {
    my ( $client, $db_ticket_id ) = @_;

    my %ai_search = (
        'ServiceName' => 'IM_GetIncidentDetailsAndChangeHistory',
        'objCommonParameters' => {
            '_ProxyDetails' => {
                'AuthType' => 'APIKEY',
                'APIKey' => $config->[0]->{summitai}->{connection}->{apikey},
                'ProxyID' => 0,
                'ReturnType' => 'JSON',
                'OrgID' => 1
            },
            'RequestType' => 'RemoteCall',
            'TicketNo' => $db_ticket_id
        }
    );

    $client->POST( $rest_endpoint, encode_json( \%ai_search ) );
    syslog('LOG_DEBUG', "SEARCH POST: " . pp ($client) );
    my $search_response = $client->responseContent();
    syslog('LOG_DEBUG', "SEARCH RESPONSE: " . encode_json( $search_response ) );
    my $json = JSON->new->allow_nonref;
    my $json_result;
    eval { $json_result = $json->decode($search_response); };
    if ($@) {
        if ( $search_response =~ /Failed to retrieve Ticket/ ) {
            return 0;
        }
        else {
            syslog('LOG_WARNING', "[incident_search] Fatal: unable to decode response from server: $search_response" );
            exit 3;
        }
    }

    if ( $debug_mode ) {
        print pp($json_result);
    }

    if ( $json_result->{OutputObject} ) {
        return $json_result->{OutputObject}->{IncidentDetails}->{TicketDetails}->[0];
    }
    else {
        return undef;
    }
}


sub send_ack {
    my ( $socket, $env_vars, $ticket_id, $debug_mode ) = @_;
    my ($string, $description);

    my $message = "Ticket ID: $ticket_id";

    if ( $env_vars->{'NAGIOS_SERVICEDESC'} ) {
        $string = join(';', '[' . time . '] ACKNOWLEDGE_SVC_PROBLEM'
            , $env_vars->{'NAGIOS_HOSTNAME'}
            , $env_vars->{'NAGIOS_SERVICEDESC'}
            , 1
            , 1
            , 0
            , 'notify_by_summitai'
            , $message
        );
    } 
    else {
        $string = join(';', '[' . time . '] ACKNOWLEDGE_HOST_PROBLEM'
            , $env_vars->{'NAGIOS_HOSTNAME'}
            , 1
            , 1
            , 0
            , 'notify_by_summitai'
            , $message
        );
    }
    if ( $debug_mode ) {
      print "ACKNOWLEDGEMENT: $string\n";
      syslog('LOG_DEBUG', "ACKNOWLEDGEMENT: $string");
    }
    open(my $fh, '>>', $socket);
    flock($fh, LOCK_EX) or die "Could not lock '$socket' - $!";
    print {$fh} "$string\n";
    close($fh);
}
