def get_args():

    parser = argparse.ArgumentParser(description=("notify_by_remedy\n"
                                                  "Copyright (C) 2003-2024 Opsview Limited. All rights reserved"))
    parser.add_argument(
        "-d",
        dest="debug",
        action="store_true",
        help="debug mode, prints errors to stderr and log file",
    )
    parser.add_argument(
        "-n",
        dest="acks",
        action="store_false",
        help="do not send acknowledgements",
    )
    parser.add_argument(
        "-m",
        dest="msg",
        help=("message to send, will override the Opsview notification data if specified"),
    )
    parser.add_argument(
        "-u",
        dest="url",
        help=("url to send the notification to"),
    )

    return parser.parse_args()


