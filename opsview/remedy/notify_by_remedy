def remedy_login(debug=True):

    headers = {
        "Content-Type": "application/json",
    }

    req = Request(
        f"{args.url}/api/jwt/login",
        auth=(F"{args.username}{args.realm}", args.password),
        headers=headers,
        method="POST",
    )

    conn = urlopen(req, timeout=5)

    if conn.status != 200:
        err_line = conn.reason
        err_message = json.loads(conn.read())
    else:
        token = req

    if debug:
        if conn.status != 200:
            print(f"Message not sent: {err_line} {err_message}")
        else:
            printf("Token: {token}")
    if debug or conn.status != 200:
        with open(LOG_FILE, "a") as fd:
            time = datetime.now().strftime("%y-%m-%d %H:%M:%S")
            fd.write(f"{time} ({conn.status}) {message}\n")
            if conn.status != 200:
                fd.write(f"{err_line}: {err_message}\n")

    return conn.status == 200

